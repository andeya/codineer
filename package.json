{
  "name": "aineer",
  "private": true,
  "version": "0.7.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "tauri": "tauri",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build",
    "test": "cargo test --workspace && bun test",
    "test:rust": "cargo test --workspace",
    "test:ui": "bun test",
    "lint": "cargo clippy --workspace --all-targets -- -D warnings && bunx biome check .",
    "lint:fix": "cargo clippy --workspace --all-targets --fix --allow-dirty && bunx biome check --fix .",
    "format": "cargo fmt --all && bunx biome format --write .",
    "format:check": "cargo fmt --all -- --check && bunx biome format .",
    "check": "cargo check --workspace --all-targets && bun run build",
    "version:patch": "bun run scripts/version-bump.ts patch",
    "version:minor": "bun run scripts/version-bump.ts minor",
    "version:major": "bun run scripts/version-bump.ts major",
    "version:set": "bun run scripts/version-bump.ts"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@tauri-apps/api": "^2.10",
    "@tauri-apps/plugin-opener": "^2",
    "@uiw/codemirror-theme-vscode": "^4.25.9",
    "@uiw/react-codemirror": "^4.25.9",
    "@xterm/addon-fit": "^0.11",
    "@xterm/addon-unicode11": "^0.9",
    "@xterm/addon-webgl": "^0.19",
    "@xterm/xterm": "^6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3",
    "use-stick-to-bottom": "^1.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4",
    "typescript": "~5.8.3",
    "vite": "^8.0.8"
  }
}
