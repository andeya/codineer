{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "webai-remote-ipc",
  "description": "Grants WebAI hidden webviews IPC event-emit access on AI provider domains",
  "windows": [
    "webai-*",
    "webauth-*"
  ],
  "local": false,
  "remote": {
    "urls": [
      "https://claude.ai/*",
      "https://*.claude.ai/*",
      "https://chatgpt.com/*",
      "https://*.chatgpt.com/*",
      "https://deepseek.com/*",
      "https://*.deepseek.com/*",
      "https://doubao.com/*",
      "https://*.doubao.com/*",
      "https://google.com/*",
      "https://*.google.com/*",
      "https://chatglm.cn/*",
      "https://*.chatglm.cn/*",
      "https://z.ai/*",
      "https://*.z.ai/*",
      "https://grok.com/*",
      "https://*.grok.com/*",
      "https://kimi.com/*",
      "https://*.kimi.com/*",
      "https://moonshot.cn/*",
      "https://*.moonshot.cn/*",
      "https://perplexity.ai/*",
      "https://*.perplexity.ai/*",
      "https://qwen.ai/*",
      "https://*.qwen.ai/*",
      "https://chat.qwen.ai/*",
      "https://qianwen.com/*",
      "https://*.qianwen.com/*",
      "https://xiaomimimo.com/*",
      "https://*.xiaomimimo.com/*"
    ]
  },
  "permissions": [
    "core:event:allow-emit"
  ]
}